 packages/common/src/schemas/metadata.ts                         | 2 +-
 .../web/src/common/store/cache/collections/createAlbumSaga.ts   | 1 -
 .../src/common/store/cache/collections/createPlaylistSaga.ts    | 1 -
 3 files changed, 1 insertion(+), 3 deletions(-)

